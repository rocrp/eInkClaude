// Timezone for the "Updated HH:MM" clock in the footer.
// TZ_OFFSET_SEC: seconds east of UTC (e.g. 8*3600 for China, -5*3600 for US Eastern)
// TZ_DST_SEC:    extra DST offset in seconds (0 if your region has no DST)
#define TZ_OFFSET_SEC         (0)
#define TZ_DST_SEC            (0)
